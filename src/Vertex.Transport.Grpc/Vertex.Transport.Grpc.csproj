<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace></RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Google.Protobuf" Version="$(GoogleProtobufVersion)" />
    <PackageReference Include="Grpc.Net.Client" Version="$(GrpcNetClientVersion)" />
    <PackageReference Include="Grpc.Tools" Version="$(GrpcToolsVersion)">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="$(MicrosoftExtensionsVersion)" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="$(MicrosoftExtensionsVersion)" />
    <PackageReference Include="Microsoft.Extensions.Options" Version="$(MicrosoftExtensionsVersion)" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Vertex.Serialization.Abstractions\Vertex.Serialization.Abstractions.csproj" />
    <ProjectReference Include="..\Vertex.Serialization.Protobuf\Vertex.Serialization.Protobuf.csproj" />
    <ProjectReference Include="..\Vertex.Transport.Abstractions\Vertex.Transport.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Vendored from dengxuan/Vertex via scripts/sync-protos.sh at the SHA in
         scripts/.spec-ref. DO NOT edit protos/**/*.proto by hand; change the spec
         repo and re-run the sync script. The generated Client + Server stubs
         bring no extra runtime dependency beyond Grpc.Core.Api (already
         transitively required by Grpc.Net.Client). -->
    <Protobuf Include="..\..\protos\vertex\transport\grpc\v1\bidi.proto"
              ProtoRoot="..\..\protos"
              GrpcServices="Both" />
  </ItemGroup>

</Project>
